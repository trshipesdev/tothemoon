# ── Telegram ──────────────────────────────────────────────────────────────
# Get a token from @BotFather. Message /start to your bot to get your
# numeric user ID, then add it to the allowlist.
TELEGRAM_TOKEN=your-bot-token-here
TELEGRAM_ALLOWLIST=123456789,987654321   # comma-separated Telegram user IDs

# ── Shadow vs Live ─────────────────────────────────────────────────────────
# true = paper trading (safe default); false = live on-chain orders
SHADOW_MODE=true

# ── Wallets ────────────────────────────────────────────────────────────────
# Never hard-code — env only. Keep these out of git.
#
# Solana: base58-encoded full keypair (64 bytes, exported from your wallet).
#   Export from Phantom: Settings → Security → Show Private Key → copy.
WALLET_PK_SOL=

# EVM: hex private key (0x-prefixed). One key is shared across all EVM chains
#   (ETH, Base, BSC, Polygon) — use a dedicated hot wallet, not your main.
WALLET_PK_EVM=

# ── State file ─────────────────────────────────────────────────────────────
STATE_PATH=./data/state.json

# ── RPC endpoints ──────────────────────────────────────────────────────────
# Without a paid RPC the public nodes will rate-limit you mid-trade.
# Recommended providers:
#   Solana: Helius (helius.dev) or QuickNode — most important, public node is unreliable
#   ETH/Base/Poly: Alchemy (alchemy.com) or Infura — free tier works for low volume
#   BSC: NodeReal (nodereal.io) or QuickNode
#
# Leave blank to fall back to public nodes (fine for testing, not for live trading).
SOL_RPC_URL=
ETH_RPC_URL=
BASE_RPC_URL=
BSC_RPC_URL=
POLY_RPC_URL=

# ── Marketplace APIs (all optional — bot degrades gracefully without them) ─
# Birdeye (https://bds.birdeye.so) — better Solana token data + trending feed
BIRDEYE_API_KEY=

# LunarCrush (https://lunarcrush.com/developers) — social mention volume
# Used as an extra gate for old-coin pump detection when mentions_x > 1 in CONFIG
LUNARCRUSH_API_KEY=

# 1inch Aggregation Protocol (https://portal.1inch.dev) — better EVM swap routing
# Falls back to direct Uniswap v3 if not set
ONEINCH_API_KEY=

# Anthropic API key (https://console.anthropic.com) — enables the AI auto-pilot
# (Claude Haiku recommends/auto-switches risk mode). Cheap. Blank = AI dormant.
ANTHROPIC_API_KEY=
# AI auto-pilot flags (so it survives restarts) — set both true to let it run + act
AI_ENABLED=
AI_AUTO_APPLY=

# X / Twitter API v2 bearer token (https://developer.twitter.com) — enables the X
# scam-chatter check in the safety gate. PAID API. Blank = X check skipped (Reddit
# + on-chain checks still run).
X_BEARER_TOKEN=

# ── Dashboard ──────────────────────────────────────────────────────────────
# Bearer token for /api/* routes. Leave blank to allow unauthenticated access
# (fine for localhost / Tailscale). Set to any random string for external access.
DASHBOARD_TOKEN=

# ── AWS ────────────────────────────────────────────────────────────────────
# Only needed for CloudWatch heartbeat metric. boto3 uses standard credential
# chain (IAM role, ~/.aws/credentials, or env vars below).
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
